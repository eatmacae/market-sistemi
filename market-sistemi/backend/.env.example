# ============================================================
# Market Yönetim Sistemi — Ortam Değişkenleri
# ============================================================
# Kurulum:
#   cp .env.example .env
#   Sonra .env içindeki değerleri doldurun.
#
# UYARI: .env dosyasını ASLA git'e eklemeyin!
# ============================================================


# ──────────────────────────────────────────────────────────
# UYGULAMA
# ──────────────────────────────────────────────────────────

APP_ENV=production          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false                 # true yapınca SQL sorguları loglanır

BRANCH_ID=1                 # Bu kurulumun şube ID'si
BRANCH_NAME=Merkez          # Şube adı (raporlarda görünür)


# ──────────────────────────────────────────────────────────
# VERİTABANI
# ──────────────────────────────────────────────────────────

# Format: postgresql://KULLANICI:SIFRE@SUNUCU:PORT/VERITABANI
DATABASE_URL=postgresql://market_user:SIFRENIZI_BURAYA@localhost:5432/market_db

# Docker Compose kullanıyorsanız 'localhost' yerine 'postgres' yazın:
# DATABASE_URL=postgresql://market_user:SIFRENIZI_BURAYA@postgres:5432/market_db


# ──────────────────────────────────────────────────────────
# GÜVENLİK — Üretim ortamında mutlaka rastgele değer üretin!
# ──────────────────────────────────────────────────────────

# JWT imzalama anahtarı (min 32 karakter)
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_GUCLU_BIR_ANAHTAR_YAZIN_EN_AZ_32_KARAKTER

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AES-256 yedek / tedarikçi şifresi şifreleme anahtarı (min 32 karakter)
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(32))"
BACKUP_ENCRYPTION_KEY=BURAYA_BASKA_BIR_GUCLU_ANAHTAR_YAZIN_32_KARAKTER


# ──────────────────────────────────────────────────────────
# E-POSTA — Stok uyarıları ve yedek raporları için
# ──────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=market@example.com
SMTP_PASSWORD=gmail_uygulama_sifresi   # Gmail → Güvenlik → Uygulama Şifreleri

# Raporların gönderileceği adres (boşsa SMTP_EMAIL kullanılır)
REPORT_EMAIL=sahip@example.com


# ──────────────────────────────────────────────────────────
# YAPAY ZEKA — PDF fatura okuma (opsiyonel)
# ──────────────────────────────────────────────────────────

# https://console.anthropic.com/settings/keys adresinden alın
# Boş bırakılırsa PDF faturalar metin çıkarmayla okunmaya çalışılır
ANTHROPIC_API_KEY=


# ──────────────────────────────────────────────────────────
# DONANIM (opsiyonel)
# ──────────────────────────────────────────────────────────

PRINTER_MAC=                    # Bluetooth termal yazıcı (örn: 00:11:22:33:44:55)
SCALE_IP=192.168.1.200          # Ağ terazisi IP
SCALE_PORT=8008                 # Ağ terazisi port
SKT_UYARI_GUN=30                # Son kullanma tarihi uyarı eşiği (gün)


# ──────────────────────────────────────────────────────────
# YEDEKLEME
# ──────────────────────────────────────────────────────────

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
